# ===== متغيرات البيئة - الحرمين للعود والعطور =====
# 1. انسخ هذا الملف وأعد تسميته إلى .env
# 2. استبدل القيم بمتغيرات Supabase الخاصة بك

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# للحصول على هذه القيم:
# 1. اذهب إلى https://supabase.com
# 2. افتح مشروعك
# 3. من Settings > API
# 4. انسخ "Project URL" و "anon/public key"
